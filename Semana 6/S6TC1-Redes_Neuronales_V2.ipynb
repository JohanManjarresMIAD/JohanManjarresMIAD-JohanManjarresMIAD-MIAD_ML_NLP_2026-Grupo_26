    "\n",
    "    model.add(Dense(num_neuronas,activation='relu'))\n",
    "    model.add(Dropout(0.1))\n",
    "\n",
    "    model.add(Dense(output_var, activation='sigmoid'))\n",
    "\n",
    "    model.compile(optimizer=optimizer, loss=loss)\n",
    "    return model\n",
